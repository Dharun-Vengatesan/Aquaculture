#include <ESP8266WiFi.h>
#include <ESP8266HTTPClient.h>

const char* ssid = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";

// Change this depending on your test
const char* testServer = "http://example.com"; 
// OR your server: http://192.168.x.x:5000

void setup() {
  Serial.begin(9600);
  delay(1000);

  Serial.println("\n===== ESP8266 DEBUG START =====");

  // 1. WiFi CONNECT
  WiFi.begin(ssid, password);
  Serial.print("Connecting WiFi");

  int timeout = 0;
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    timeout++;
    if (timeout > 30) {
      Serial.println("\nWiFi FAILED ❌");
      return;
    }
  }

  Serial.println("\nWiFi CONNECTED ✔");

  // 2. Network Info
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  Serial.print("Gateway: ");
  Serial.println(WiFi.gatewayIP());

  Serial.print("DNS: ");
  Serial.println(WiFi.dnsIP());

  // 3. DNS TEST
  IPAddress ip;
  Serial.println("\nTesting DNS (google.com)...");
  if (WiFi.hostByName("google.com", ip)) {
    Serial.println("DNS OK ✔");
  } else {
    Serial.println("DNS FAILED ❌");
  }

  // 4. INTERNET TEST
  Serial.println("\nTesting HTTP connection...");

  WiFiClient client;
  HTTPClient http;

  http.begin(client, testServer);

  int httpCode = http.GET();

  if (httpCode > 0) {
    Serial.print("HTTP Response Code: ");
    Serial.println(httpCode);
    Serial.println("SERVER REACHABLE ✔");
  } else {
    Serial.print("HTTP FAILED ❌ Code: ");
    Serial.println(httpCode);
    Serial.println("SERVER NOT REACHABLE");
  }

  http.end();

  Serial.println("\n===== DEBUG COMPLETE =====");
}

void loop() {
}
